{
  "name": "nebula",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "pnpm --filter nebula-mcp build",
    "build:landing": "pnpm --filter nebula-landing build",
    "build:web": "pnpm --filter nebula-frontend build",
    "build:mcpb": "pnpm --filter nebula-mcp build:mcpb",
    "dev:landing": "pnpm --filter nebula-landing dev",
    "dev:mcp": "pnpm --filter nebula-mcp dev",
    "dev:web": "pnpm --filter nebula-frontend dev",
    "publish:mcp": "pnpm --filter nebula-mcp publish --access public",
    "vercel:configure": "node scripts/configure-vercel.mjs"
  }
}
