# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env — it contains your secret key.

# Stellar secret key (starts with S...)
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Network: testnet (default) or mainnet
NETWORK=testnet

# Spending limits (agent outgoing: transfers + x402 only — NOT treasury rebalancing)
# Required when POLICY_CONTRACT_ID is unset (off-chain limits). Optional when using on-chain policy.
MAX_PER_CALL=100
MAX_PER_DAY=500

# On-chain spending policy (Soroban nebula-policy contract)
# When set, transfers/x402/MPP/Blend agent spends enforce + record via check_spend on-chain.
# Example testnet deployment: CDAXOPVILENGGLPU3CNOOS53P255PUAVODI4EAJC6A4VIZQT3BAMVTXP
# POLICY_CONTRACT_ID=CDAXOPVILENGGLPU3CNOOS53P255PUAVODI4EAJC6A4VIZQT3BAMVTXP
# POLICY_WASM_PATH=/custom/path/to/policy.wasm

# Treasury / yield engine (defaults to XLM on testnet)
# Asset to manage: xlm (default) or usdc
TREASURY_ASSET=xlm
# Native XLM kept for fees when TREASURY_ASSET=xlm
XLM_FEE_BUFFER=5
# Optional cap per rebalance move (unset or 0 = move full excess/deficit in one tx)
# TREASURY_MAX_PER_REBALANCE=5000
# Minimum liquid balance to keep on hand; excess is auto-deposited to Blend
LIQUIDITY_THRESHOLD=10
# Background rebalance interval in seconds
REBALANCE_INTERVAL_SECONDS=60
