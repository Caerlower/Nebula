{
  "name": "nebula-mcp",
  "version": "1.0.0",
  "description": "Stellar MCP wallet for AI agents — 23 tools: x402/MPP payments, Blend treasury, on-chain policy, 8004 identity, in-chat dashboard",
  "type": "module",
  "license": "MIT",
  "author": "Nebula",
  "homepage": "https://github.com/manavgoyal/Nebula#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manavgoyal/Nebula.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/manavgoyal/Nebula/issues"
  },
  "keywords": [
    "stellar",
    "mcp",
    "wallet",
    "x402",
    "mpp",
    "soroban",
    "ai-agents",
    "model-context-protocol",
    "usdc",
    "blend",
    "stellar8004"
  ],
  "main": "dist/index.js",
  "bin": {
    "nebula-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "manifest.json",
    "assets",
    "README.md",
    "INSTALL.md",
    "TOOLS.md",
    "LICENSE",
    "mcp.example.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && node scripts/build/bundle-dashboard.mjs && mkdir -p dist/contracts && cp contracts/channel.wasm dist/contracts/channel.wasm && cp contracts/policy.wasm dist/contracts/policy.wasm",
    "build:mcpb": "bash scripts/build/build-mcpb.sh",
    "prepack": "pnpm run build && node scripts/build/strip-publish-artifacts.mjs",
    "start": "node dist/index.js",
    "dev": "node scripts/dev/watch.mjs"
  },
  "dependencies": {
    "@blend-capital/blend-sdk": "^3.3.0",
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stellar/mpp": "0.7.1",
    "@stellar/stellar-sdk": "^16.0.1",
    "@trionlabs/stellar8004": "0.0.11",
    "@x402/core": "~2.17.0",
    "@x402/stellar": "~2.17.0",
    "mppx": "0.8.6",
    "viem": "^2.55.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@x402/express": "^2.17.0",
    "esbuild": "^0.25.0",
    "express": "^5.2.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
