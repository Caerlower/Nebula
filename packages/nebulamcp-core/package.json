{
  "name": "nebulamcp-core",
  "version": "0.1.0",
  "description": "Transport-agnostic Nebula tool schemas and handlers. No MCP or HTTP.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^16.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Caerlower/Nebula.git",
    "directory": "packages/nebulamcp-core"
  },
  "homepage": "https://nebulaonchain.xyz",
  "keywords": [
    "stellar",
    "mcp",
    "wallet",
    "x402",
    "mpp",
    "soroban",
    "ai-agents",
    "blend"
  ]
}
