generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct connection for prisma migrate / db push (Supabase "Direct connection")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String   @id @default(cuid())
  /// Null for wallet-native (Freighter / EOA) accounts — dapp sign-in has no Privy user.
  privyUserId        String?  @unique
  /// Optional: dapp accounts identify by wallet address, not email.
  email              String?  @unique
  name               String?
  privyWalletId      String?  @unique
  stellarAddress     String?  @unique
  /// How this account holds funds: "custodial" (Privy) or "external" (self-custody EOA).
  accountType        String   @default("custodial")
  /// Where signatures come from: "privy" | "partner_callback" | "client_side".
  signerStrategy     String   @default("privy")
  /// On-chain Stellar8004 agent id for this wallet (null until register_identity).
  stellar8004AgentId Int?
  /// Cached Stellar8004 avgScore (0–100).
  reputationScore    Int      @default(0)
  /// Cached confidence: unrated | low | medium | high
  reputationTier     String   @default("unrated")
  createdAt          DateTime @default(now())

  tokens           NebulaToken[]
  agents           Agent[]
  transactions     Transaction[]
  confirmations    Confirmation[]
  whitelistEntries WhitelistEntry[]
  denylistEntries  DenylistEntry[]
  policySettings   PolicySettings?
  mppSessions      MppSession[]
}

model NebulaToken {
  id         String    @id @default(cuid())
  userId     String
  agentId    String?
  label      String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  /// When set, token is invalid after this time (OAuth access tokens). Null = until revoked.
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id])
  agent Agent? @relation(fields: [agentId], references: [id])
}

model Agent {
  id                 String   @id @default(cuid())
  userId             String
  name               String
  framework          String
  status             String   @default("active")
  /// What this agent is for — free-text purpose set at creation.
  description        String?
  /// Optional avatar hue (0–359) chosen at creation; null = deterministic from name.
  avatarColor        String?
  /// Agent's own managed wallet (Privy) id. Null for legacy agents (fall back to
  /// owner wallet) and for partner_callback agents whose key lives off-Hub.
  privyWalletId      String?  @unique
  /// Agent's own Stellar address. For partner_callback (e.g. Tael) this is the
  /// external card address the partner signs for.
  stellarAddress     String?  @unique
  /// How this agent's wallet holds funds: "custodial" (Nebula/Privy) or "external".
  accountType        String   @default("custodial")
  /// Where this agent's spend signatures come from: "privy" | "partner_callback" | "client_side".
  signerStrategy     String   @default("privy")
  /// This agent's OWN on-chain Stellar8004 agent id (null until register_identity
  /// runs for this agent's wallet). Each agent is an independent identity.
  stellar8004AgentId Int?
  /// Cached Stellar8004 avgScore (0–100) for this agent's own identity.
  reputationScore    Int      @default(0)
  reputationTier     String   @default("unrated")
  createdAt          DateTime @default(now())

  user   User          @relation(fields: [userId], references: [id])
  tokens NebulaToken[]
  policy AgentPolicy?
}

model Transaction {
  id             String   @id @default(cuid())
  userId         String
  agentId        String?
  type           String
  destination    String
  amountXlm      Decimal  @db.Decimal(18, 7)
  memo           String?
  reason         String
  txHash         String?  @unique
  status         String
  confirmationId String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Confirmation {
  id         String    @id @default(cuid())
  userId     String
  toolName   String
  input      Json
  summary    String
  status     String    @default("pending")
  expiresAt  DateTime
  approvedAt DateTime?
  txHash     String?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model WhitelistEntry {
  id        String   @id @default(cuid())
  userId    String
  address   String
  label     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, address])
}

model DenylistEntry {
  id        String   @id @default(cuid())
  userId    String
  address   String
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, address])
}

model PolicySettings {
  userId          String  @id
  /// Confirmation micro threshold (USDC).
  microThreshold  Decimal @default(0.1) @db.Decimal(18, 7)
  /// Per-transaction spend cap (USDC).
  perTxCap        Decimal @default(5) @db.Decimal(18, 7)
  /// Global daily spend cap (USDC).
  dailyCap        Decimal @default(20) @db.Decimal(18, 7)
  paused          Boolean @default(false)
  autoYield       Boolean @default(true)
  /// Liquid band low (USDC): pull from Blend when liquid XLM value falls below this.
  liquidThreshold Decimal @default(2) @db.Decimal(18, 7)
  /// Liquid band high (USDC): park excess to Blend when liquid XLM value rises above this.
  liquidHigh      Decimal @default(10) @db.Decimal(18, 7)
  /// Per-category daily caps (USDC). XLM transfers convert via oracle. Blend not capped.
  catTransfer     Decimal @default(20) @db.Decimal(18, 7)
  catX402         Decimal @default(5) @db.Decimal(18, 7)
  catMpp          Decimal @default(5) @db.Decimal(18, 7)

  user User @relation(fields: [userId], references: [id])
}

/// Per-agent spend caps. When absent, an agent inherits the owner's
/// PolicySettings cap *values* (but keeps its own, isolated spend counter).
/// Whitelist/denylist and the treasury band stay owner-level.
model AgentPolicy {
  agentId        String   @id
  /// Confirmation micro threshold (USDC).
  microThreshold Decimal  @default(0.1) @db.Decimal(18, 7)
  /// Per-transaction spend cap (USDC).
  perTxCap       Decimal  @default(5) @db.Decimal(18, 7)
  /// Agent daily spend cap (USDC).
  dailyCap       Decimal  @default(20) @db.Decimal(18, 7)
  paused         Boolean  @default(false)
  /// Per-category daily caps (USDC).
  catTransfer    Decimal  @default(20) @db.Decimal(18, 7)
  catX402        Decimal  @default(5) @db.Decimal(18, 7)
  catMpp         Decimal  @default(5) @db.Decimal(18, 7)
  updatedAt      DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

/// Active MPP payment-channel session (one open session per agent; owner-level
/// sessions use a null agentId).
model MppSession {
  id                  String    @id @default(cuid())
  userId              String
  /// Which agent owns this channel. Null = owner/dashboard-level session.
  agentId             String?
  channel             String
  recipient           String
  budgetUsdc          Decimal   @db.Decimal(18, 7)
  budgetStroops       String
  cumulativeStroops   String    @default("0")
  commitmentSecretHex String
  commitmentPubkeyHex String
  networkId           String
  status              String    @default("open")
  openedAt            DateTime  @default(now())
  closedAt            DateTime?
  closeTxHash         String?
  deployWasmHash      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, agentId, status])
}

/// OAuth Dynamic Client Registration (MCP remote connectors).
model OAuthClient {
  clientId         String   @id
  clientSecretHash String?
  clientName       String?
  redirectUris     Json
  createdAt        DateTime @default(now())
}

model OAuthAuthorizationCode {
  codeHash            String    @id
  clientId            String
  userId              String
  /// Agent whose wallet this OAuth grant will operate. Required for new grants;
  /// null only for legacy codes issued before per-agent OAuth.
  agentId             String?
  redirectUri         String
  codeChallenge       String
  codeChallengeMethod String    @default("S256")
  expiresAt           DateTime
  usedAt              DateTime?
  createdAt           DateTime  @default(now())
}

/// Landing waitlist — managed via service-role client; keep in schema so db push won't drop it.
model Waitlist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  source    String   @default("landing")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("waitlist")
}
