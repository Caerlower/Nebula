# --- App ---
# Production: set both to the public HTTPS origin (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
# Deliberate: testnet | mainnet. Default in code is testnet if unset.
STELLAR_NETWORK=testnet
# Native XLM reserved for fees when depositing to Blend (default 5)
# XLM_FEE_BUFFER=5

# --- Private beta ---
# Required in production (comma-separated). Locally defaults to NEBULA-CREW
# when unset — never leave production without this.
NEBULA_BETA_CODES=NEBULA-CREW

# --- Supabase (waitlist REST) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma / Supabase Postgres ---
DATABASE_URL=
DIRECT_URL=
# Cap Prisma pool size (default: 5 in dev, 3 in prod). Raises if you see P2024 pool timeouts.
# PRISMA_CONNECTION_LIMIT=5

# --- Privy (login + server wallets / signing) ---
# Client (must match PRIVY_APP_ID)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Authorization key from Privy Dashboard → Wallet infrastructure → Keys and quorums → New key.
# Usually looks like: wallet-auth:MIGHAgEAMBMGByqGSM49AgEGCCqG...
# (Privy does not store the private key — copy it when creating.)
PRIVY_AUTHORIZATION_PRIVATE_KEY=

# --- On-chain spending policy (Soroban nebula-policy) ---
# Deploy wasm from contracts/policy, then set the shared contract id (C…).
# When unset, Hub still enforces caps in Postgres; transfers skip check_spend.
# POLICY_CONTRACT_ID=

# --- x402 (optional overrides) ---
# STELLAR_TESTNET_RPC_URL=https://soroban-testnet.stellar.org
# STELLAR_MAINNET_RPC_URL=https://mainnet.sorobanrpc.com
# Buyer wallets need a Circle USDC trustline + balance (testnet: Circle faucet).

# --- MPP channels (optional) ---
# Default recipient when mpp_open_session omits recipient:
# MPP_RECIPIENT=G...
# Optional override for channel.wasm path (defaults to apps/nebula-hub/contracts/channel.wasm):
# MPP_CHANNEL_WASM_PATH=
# Demo merchant at /api/mpp-demo/[channel] — disabled unless this is set (no default).
# MPP_DEMO_SECRET=
# MPP_DEMO_PRICE=0.01

# --- OAuth DCR (MCP Dynamic Client Registration) ---
# open = any https + localhost (legacy). restricted (default) = localhost /
# loopback / private IPs / optional allowlist only. disabled = 404.
# OAUTH_DCR_MODE=restricted
# Comma-separated extra https hosts allowed when restricted (e.g. cursor.sh)
# OAUTH_DCR_REDIRECT_HOSTS=
# Optional shared secret: require Authorization: Bearer <secret> to register.
# OAUTH_DCR_SECRET=

# --- Stellar8004 (on-chain agent identity / reputation) ---
# Optional explorer override (default https://stellar8004.com):
# STELLAR8004_EXPLORER_URL=https://stellar8004.com
# Optional metadata defaults for register_identity:
# AGENT8004_NAME=Nebula Agent
# AGENT8004_DESCRIPTION=Autonomous Stellar agent wallet
# AGENT8004_IMAGE_URL=

# Optional fixed XLM/USD for spend-cap conversion (skips CoinGecko). Tests / offline only.
# Live path uses CoinGecko: GET https://api.coingecko.com/api/v3/simple/price?ids=stellar&vs_currencies=usd
# XLM_USD_PRICE=0.12

# --- Optional rate limits ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Local demos ONLY — never set on Vercel / production ---
# Full auth bypass via x-nebula-dev-mint. Ignored when NODE_ENV=production or VERCEL=1.
# DEV_MINT_SECRET=
# DEV_USER_EMAIL=dev@nebula.local
